rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /work_records/{recordId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && request.resource.data.date is string
          && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.keys().hasAll(['date', 'updatedAt'])
          && (!request.resource.data.keys().hasAny(['giris']) || request.resource.data.giris.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['cikis']) || request.resource.data.cikis.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['molaGiris']) || request.resource.data.molaGiris.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['molaCikis']) || request.resource.data.molaCikis.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['girisTimestamp']) || (request.resource.data.girisTimestamp is int && request.resource.data.girisTimestamp > 1577836800000 && request.resource.data.girisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['cikisTimestamp']) || (request.resource.data.cikisTimestamp is int && request.resource.data.cikisTimestamp > 1577836800000 && request.resource.data.cikisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['molaGirisTimestamp']) || (request.resource.data.molaGirisTimestamp is int && request.resource.data.molaGirisTimestamp > 1577836800000 && request.resource.data.molaGirisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['molaCikisTimestamp']) || (request.resource.data.molaCikisTimestamp is int && request.resource.data.molaCikisTimestamp > 1577836800000 && request.resource.data.molaCikisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['isHoliday']) || request.resource.data.isHoliday is bool)
          && (!request.resource.data.keys().hasAny(['breakCounted']) || request.resource.data.breakCounted is bool);
        
        allow update: if isOwner(userId)
          && resource.data.date == request.resource.data.date
          && request.resource.data.date is string
          && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && (!request.resource.data.keys().hasAny(['giris']) || request.resource.data.giris.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['cikis']) || request.resource.data.cikis.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['molaGiris']) || request.resource.data.molaGiris.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['molaCikis']) || request.resource.data.molaCikis.matches('^[0-9]{2}:[0-9]{2}$'))
          && (!request.resource.data.keys().hasAny(['girisTimestamp']) || (request.resource.data.girisTimestamp is int && request.resource.data.girisTimestamp > 1577836800000 && request.resource.data.girisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['cikisTimestamp']) || (request.resource.data.cikisTimestamp is int && request.resource.data.cikisTimestamp > 1577836800000 && request.resource.data.cikisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['molaGirisTimestamp']) || (request.resource.data.molaGirisTimestamp is int && request.resource.data.molaGirisTimestamp > 1577836800000 && request.resource.data.molaGirisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['molaCikisTimestamp']) || (request.resource.data.molaCikisTimestamp is int && request.resource.data.molaCikisTimestamp > 1577836800000 && request.resource.data.molaCikisTimestamp < 1893456000000))
          && (!request.resource.data.keys().hasAny(['isHoliday']) || request.resource.data.isHoliday is bool)
          && (!request.resource.data.keys().hasAny(['breakCounted']) || request.resource.data.breakCounted is bool);
      }
    }

    // Game Leaderboard - Snake, Tetris (skor bazlı)
    match /game_leaderboard/{game}/records/{userCode} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.resource.data.userCode == userCode
        && request.resource.data.keys().hasAll(['userCode', 'displayName', 'bestScore', 'updatedAt'])
        && request.resource.data.bestScore is number;
      allow delete: if false;
    }

    // Sudoku Leaderboard - herkes okuyabilir, giriş yapmış kullanıcılar yazabilir
    match /sudoku_leaderboard/{difficulty}/records/{userCode} {
      allow read: if true;
      allow create, update: if isAuthenticated()
        && request.resource.data.keys().hasAll(['userCode', 'displayName', 'bestTime', 'updatedAt'])
        && request.resource.data.bestTime is int
        && request.resource.data.bestTime > 0
        && request.resource.data.userCode is string
        && request.resource.data.displayName is string;
      allow delete: if false;
    }
    
    // Diğer tüm koleksiyonlara erişim yasak
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
