# Firebase (JS SDK — config/firebase.ts)
# iOS: GoogleService-Info.plist | Android: google-services.json değerlerini kullanın
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# iOS: GOOGLE_APP_ID (ios:...) | Android: mobilesdk_app_id (android:...)
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In iOS client ID (GoogleService-Info.plist → CLIENT_ID)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# RevenueCat — Test Store: test_... | Production: appl_... (iOS) / goog_... (Android)
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=

# EAS Build secrets (app.config.js) — yerel dosya yerine kullanılabilir
# GOOGLE_SERVICES_JSON=
# GOOGLE_SERVICES_INFO_PLIST=

# Tanıtım sitesi — ayarlardan gizlilik / kullanım koşulları / impressum linkleri
EXPO_PUBLIC_WEBSITE_URL=https://klickzeit-webside.ttimocin.workers.dev
